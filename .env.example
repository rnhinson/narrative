# Slack App Credentials
# Get these from https://api.slack.com/apps → Your App → Basic Information
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
# Generate at api.slack.com/apps → Your App → Socket Mode → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here

# Jira Credentials (org-wide fallback -- channels can set their own via
# /point-config instead; a channel needs one or the other before /point works)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-jira-email@company.com
# Generate an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token-here

# Key used to encrypt per-channel Jira API tokens at rest in config-store.json
# (the org-wide JIRA_API_TOKEN above is a plain env var and doesn't need this --
# only tokens saved via /point-config are encrypted). Generate one with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required before any channel can save its own Jira API token; without it,
# /point-config will save the rest of a channel's settings but reject the
# token field with an error telling the user to contact an admin.
CONFIG_ENCRYPTION_KEY=

# Jira Workflow Config (org-wide defaults — can be overridden per channel with /point-config)
JIRA_LABELS_TO_REMOVE=needs-pointing,unpointed
JIRA_TARGET_STATUS=Ready for Sprint
# Comma-separated project short codes the bot may point org-wide (e.g. PLAT,INFRA).
# Channels without this set (or their own /point-config override) can't use
# /point at all until they configure their allowed project(s).
JIRA_ALLOWED_PROJECTS=
# Find your field ID: curl -u email:token https://yourcompany.atlassian.net/rest/api/3/field | grep -i "story point"
JIRA_STORY_POINTS_FIELD=customfield_10016

# Data directory for persisting per-channel configs (leave blank for project root)
# DATA_DIR=/app/data
