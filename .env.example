# Slack App Credentials
# Get these from https://api.slack.com/apps → Your App → Basic Information
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
# Generate at api.slack.com/apps → Your App → Socket Mode → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here

# Jira Credentials
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-jira-email@company.com
# Generate an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token-here

# Jira Workflow Config (org-wide defaults — can be overridden per channel with /point-config)
JIRA_LABELS_TO_REMOVE=needs-pointing,unpointed
JIRA_TARGET_STATUS=Ready for Sprint
# Find your field ID: curl -u email:token https://yourcompany.atlassian.net/rest/api/3/field | grep -i "story point"
JIRA_STORY_POINTS_FIELD=customfield_10016

# Data directory for persisting per-channel configs (leave blank for project root)
# DATA_DIR=/app/data
